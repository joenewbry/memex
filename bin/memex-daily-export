#!/usr/bin/env python3
"""
Memex Daily Export — generates a markdown summary of the day's activity.

Reads OCR data files directly (no MCP dependency) and writes a summary to
~/.memex/summaries/YYYY-MM-DD.md with convenience symlinks for today/yesterday.

On Prometheus (Jetson), generates per-instance summaries under
~/.memex/summaries/{instance}/YYYY-MM-DD.md.

Usage:
    memex-daily-export                     # Export today (auto-detect instance)
    memex-daily-export 2026-03-07          # Export specific date
    memex-daily-export --instance alaska   # Export specific instance
    memex-daily-export --all-instances     # Export all Prometheus instances
    memex-daily-export --rotate            # Just rotate today/yesterday symlinks
"""

import json
import os
import sys
from datetime import datetime, timedelta
from pathlib import Path
from typing import Dict, List, Optional, Any

SUMMARIES_DIR = Path.home() / ".memex" / "summaries"
PROMETHEUS_DATA_ROOT = Path("/ssd/memex/data")

# Time-of-day periods
PERIODS = [
    ("Early Morning", 5, 8),
    ("Morning", 8, 12),
    ("Afternoon", 12, 17),
    ("Evening", 17, 21),
    ("Night", 21, 24),
    ("Late Night", 0, 5),
]


def get_instance_name() -> str:
    """Determine instance name from config."""
    config_file = Path.home() / ".memex" / "instance.json"
    if config_file.exists():
        try:
            with open(config_file) as f:
                return json.load(f).get("instance_name", "default")
        except Exception:
            pass
    return "default"


def is_prometheus() -> bool:
    """Detect if running on Prometheus (Jetson)."""
    return PROMETHEUS_DATA_ROOT.exists()


def find_ocr_dir(instance: Optional[str] = None) -> Optional[Path]:
    """Find the OCR data directory, checking multiple locations."""
    candidates = []

    if instance and is_prometheus():
        # Prometheus: instance-specific path
        candidates.append(PROMETHEUS_DATA_ROOT / instance / "ocr")
    else:
        # Local machine: prefer ~/.memex (active capture dir) over dev repo
        candidates.extend([
            Path.home() / ".memex" / "refinery" / "data" / "ocr",
            Path(__file__).resolve().parent.parent / "refinery" / "data" / "ocr",
        ])
        # Also check Prometheus paths if available
        inst = instance or get_instance_name()
        if is_prometheus():
            candidates.append(PROMETHEUS_DATA_ROOT / inst / "ocr")

    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


def get_all_instances() -> List[str]:
    """Get all instance names from Prometheus data directory."""
    if not is_prometheus():
        return []
    return [d.name for d in PROMETHEUS_DATA_ROOT.iterdir()
            if d.is_dir() and (d / "ocr").exists()]


def parse_filename_timestamp(filename: str) -> Optional[datetime]:
    """Parse timestamp from OCR filename like 2026-03-08T14-30-05-123456_ocr.json."""
    try:
        if not filename.endswith(".json"):
            return None
        timestamp_part = filename.split("_")[0]
        parts = timestamp_part.split("T")
        if len(parts) != 2:
            return None
        date_part, time_part = parts
        time_components = time_part.split("-")
        if len(time_components) < 3:
            return None
        hour, minute = time_components[0], time_components[1]
        if len(time_components) >= 4:
            second = time_components[2]
        else:
            second = time_components[2].split(".")[0]
        return datetime.fromisoformat(f"{date_part}T{hour}:{minute}:{second}")
    except Exception:
        return None


def get_period(hour: int) -> str:
    """Return the time-of-day period label for a given hour."""
    for label, start, end in PERIODS:
        if start <= hour < end:
            return label
    return "Late Night"


def load_day_captures(ocr_dir: Path, target_date) -> List[Dict[str, Any]]:
    """Load all OCR captures for a given date."""
    captures = []
    day_prefix = target_date.isoformat()

    for f in ocr_dir.iterdir():
        if not f.name.endswith(".json"):
            continue
        if not f.name.startswith(day_prefix):
            continue

        ts = parse_filename_timestamp(f.name)
        if not ts:
            continue

        try:
            with open(f, "r", encoding="utf-8") as fh:
                data = json.load(fh)
        except Exception:
            continue

        text = data.get("text", "")
        captures.append({
            "timestamp": ts,
            "hour": ts.hour,
            "screen_name": data.get("screen_name", "unknown"),
            "word_count": len(text.split()) if text else 0,
            "text": text,
        })

    captures.sort(key=lambda c: c["timestamp"])
    return captures


def sample_evenly(items: list, n: int) -> list:
    """Return up to n items evenly distributed."""
    if len(items) <= n:
        return items
    step = len(items) / n
    return [items[int(i * step)] for i in range(n)]


def generate_summary(target_date, captures: List[Dict], instance: Optional[str] = None) -> str:
    """Generate markdown summary from captures."""
    date_str = target_date.isoformat()
    weekday = target_date.strftime("%A")

    title = f"# Memex Daily Summary — {weekday}, {date_str}"
    if instance:
        title += f" ({instance})"

    lines = [title, ""]

    if not captures:
        lines.append("No captures recorded for this day.")
        return "\n".join(lines)

    # Stats
    total = len(captures)
    total_words = sum(c["word_count"] for c in captures)
    unique_screens = sorted(set(c["screen_name"] for c in captures))
    active_hours = sorted(set(c["hour"] for c in captures))
    first_ts = captures[0]["timestamp"].strftime("%H:%M")
    last_ts = captures[-1]["timestamp"].strftime("%H:%M")

    lines.extend([
        f"**Captures:** {total} | **Words:** {total_words:,} | **Active hours:** {len(active_hours)}",
        f"**First activity:** {first_ts} | **Last activity:** {last_ts}",
        f"**Screens:** {', '.join(unique_screens)}",
        "",
    ])

    # Group by period
    period_buckets: Dict[str, List[Dict]] = {}
    for cap in captures:
        period = get_period(cap["hour"])
        period_buckets.setdefault(period, []).append(cap)

    for label, start_h, end_h in PERIODS:
        bucket = period_buckets.get(label, [])
        if not bucket:
            continue

        period_words = sum(c["word_count"] for c in bucket)
        period_screens = sorted(set(c["screen_name"] for c in bucket))
        lines.extend([
            f"## {label} ({start_h:02d}:00–{end_h:02d}:00)",
            f"{len(bucket)} captures, {period_words:,} words — {', '.join(period_screens)}",
            "",
        ])

        # Show a few sample snippets
        samples = sample_evenly(bucket, 3)
        for s in samples:
            time_str = s["timestamp"].strftime("%H:%M")
            snippet = s["text"][:200].replace("\n", " ").strip()
            if len(s["text"]) > 200:
                snippet += "..."
            if snippet:
                lines.append(f"- **{time_str}** [{s['screen_name']}]: {snippet}")
        lines.append("")

    return "\n".join(lines)


def rotate_symlinks(summaries_dir: Path, today_date):
    """Update today.md and yesterday.md symlinks."""
    yesterday_date = today_date - timedelta(days=1)

    today_file = summaries_dir / f"{today_date.isoformat()}.md"
    yesterday_file = summaries_dir / f"{yesterday_date.isoformat()}.md"

    today_link = summaries_dir / "today.md"
    yesterday_link = summaries_dir / "yesterday.md"

    if today_file.exists():
        today_link.unlink(missing_ok=True)
        today_link.symlink_to(today_file.name)

    if yesterday_file.exists():
        yesterday_link.unlink(missing_ok=True)
        yesterday_link.symlink_to(yesterday_file.name)


def export_instance(target_date, instance: Optional[str] = None):
    """Export daily summary for a single instance."""
    ocr_dir = find_ocr_dir(instance)
    if not ocr_dir:
        print(f"No OCR data directory found for instance '{instance or 'local'}'.", file=sys.stderr)
        return

    # Per-instance subdirectory on Prometheus, flat on local
    if instance and is_prometheus():
        out_dir = SUMMARIES_DIR / instance
    else:
        out_dir = SUMMARIES_DIR

    out_dir.mkdir(parents=True, exist_ok=True)

    captures = load_day_captures(ocr_dir, target_date)
    summary = generate_summary(target_date, captures, instance)

    output_file = out_dir / f"{target_date.isoformat()}.md"
    output_file.write_text(summary, encoding="utf-8")
    print(f"Wrote {output_file} ({len(captures)} captures)")

    if target_date == datetime.now().date():
        rotate_symlinks(out_dir, target_date)


def main():
    SUMMARIES_DIR.mkdir(parents=True, exist_ok=True)

    args = sys.argv[1:]

    # Parse flags
    rotate_only = "--rotate" in args
    all_instances = "--all-instances" in args
    instance = None
    target_date = None

    if "--instance" in args:
        idx = args.index("--instance")
        if idx + 1 < len(args):
            instance = args[idx + 1]

    # Parse date (first positional arg that looks like a date)
    for arg in args:
        if arg.startswith("--"):
            continue
        if arg == instance:
            continue
        try:
            target_date = datetime.strptime(arg, "%Y-%m-%d").date()
        except ValueError:
            pass

    if target_date is None:
        target_date = datetime.now().date()

    # Handle --rotate
    if rotate_only:
        if all_instances and is_prometheus():
            for inst in get_all_instances():
                inst_dir = SUMMARIES_DIR / inst
                if inst_dir.exists():
                    rotate_symlinks(inst_dir, target_date)
            print(f"Rotated symlinks for all instances.")
        else:
            rotate_symlinks(SUMMARIES_DIR, target_date)
            print("Rotated symlinks.")
        return

    # Handle --all-instances (Prometheus only)
    if all_instances:
        instances = get_all_instances()
        if not instances:
            print("No instances found (not on Prometheus?).", file=sys.stderr)
            sys.exit(1)
        for inst in instances:
            export_instance(target_date, inst)
        return

    # Single instance export
    if instance:
        export_instance(target_date, instance)
    elif is_prometheus():
        # On Prometheus with no --instance: export all
        for inst in get_all_instances():
            export_instance(target_date, inst)
    else:
        # Local machine
        export_instance(target_date)


if __name__ == "__main__":
    main()
